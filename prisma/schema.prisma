generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
}

model Paper {
  id            Int      @id @default(autoincrement())
  title         String
  authors       String?
  venue         String?
  type          String   @default("journal")
  doi           String?
  place         String?
  date          String?
  year          Int?
  link          String?
  description   String?
  createdAt     DateTime @default(now())
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String
  publisher     String?
  year          Int?
  link          String?
  coverImage    String?
  description   String?
  createdAt     DateTime @default(now())
}

model Education {
  id            Int      @id @default(autoincrement())
  degree        String
  institution   String
  yearStart     String?
  yearEnd       String?
  description   String?
  createdAt     DateTime @default(now())
}

model Experience {
  id            Int      @id @default(autoincrement())
  title         String
  organization  String
  dateRange     String?
  description   String?
  type          String   @default("work") // 'work', 'volunteer', 'research'
  image         String?
  createdAt     DateTime @default(now())
}

model Award {
  id            Int      @id @default(autoincrement())
  title         String
  issuer        String?
  year          String?
  createdAt     DateTime @default(now())
}

model Certificate {
  id            Int      @id @default(autoincrement())
  name          String
  issuer        String?
  year          String?
  type          String   @default("academic") 
  link          String?
  image         String?
  createdAt     DateTime @default(now())
}

model Project {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  image         String?
  link          String?
  githubLink    String?
  youtubeLink   String?
  createdAt     DateTime @default(now())
}

model BlogPost {
  id            Int       @id @default(autoincrement())
  title         String
  slug          String    @unique
  content       String
  image         String?
  video         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      Comment[]
}

model Comment {
  id            Int       @id @default(autoincrement())
  authorName    String
  content       String
  approved      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  postId        Int
  post          BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
}
